---
import { sanityClient } from '../sanityClient';

// This asks Sanity for the Title and the secret URL of the PDF file
const lectures = await sanityClient.fetch(`*[_type == "lecture"]{
  title,
  "fileURL": lecture.asset->url
}`);

const title = "Student Lecture Library";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<main style="max-width: 800px; margin: 40px auto; font-family: sans-serif; padding: 0 20px;">
			<h1 style="color: #333; border-bottom: 2px solid #eee; padding-bottom: 10px;">
				📚 {title}
			</h1>

			<p style="color: #666; margin-bottom: 30px;">
				Welcome! Below is the list of available lectures. Click the link to download the PDF.
			</p>

			{lectures.length > 0 ? (
				<ul style="list-style: none; padding: 0;">
					{lectures.map((lecture) => (
						<li style="background: #f9f9f9; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 15px; padding: 15px; display: flex; justify-content: space-between; align-items: center;">
							<span style="font-weight: bold; color: #444;">{lecture.title}</span>
							
							{lecture.fileURL ? (
								<a 
									href={`${lecture.fileURL}?dl=`} 
									target="_blank" 
									style="background: #0070f3; color: white; padding: 8px 16px; border-radius: 5px; text-decoration: none; font-size: 14px;"
								>
									Download PDF
								</a>
							) : (
								<span style="color: #999; font-size: 12px;">No file attached</span>
							)}
						</li>
					))}
				</ul>
			) : (
				<div style="text-align: center; padding: 40px; background: #fff8f8; border: 1px dashed #ffcccc; border-radius: 8px;">
					<p style="color: #cc0000;">No lectures found. Make sure you have "Published" them in Sanity!</p>
				</div>
			)}
		</main>
	</body>
</html>