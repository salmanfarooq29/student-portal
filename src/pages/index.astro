---
import { sanityClient } from '../sanityClient';

const data = await sanityClient.fetch(`{
  "lectures": *[_type == "lecture"] | order(_createdAt desc) {
    title,
    "fileURL": pdfFile.asset->url
  },
  "articles": *[_type == "article"] | order(date desc) {
    title,
    content,
    date
  }
}`);

const { lectures, articles } = data;
const siteTitle = "Lectures Library";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{siteTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
	</head>
	<body style="margin: 0; font-family: 'Inter', sans-serif; background-color: #f8fafc; color: #1e293b; line-height: 1.5;">
		
		<header style="background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%); padding: 80px 20px; text-align: center; color: white;">
			<div style="max-width: 1000px; margin: 0 auto;">
				<h1 style="font-size: 3rem; margin: 0; letter-spacing: -1px; font-weight: 800;">🎓 {siteTitle}</h1>
				<p style="font-size: 1.1rem; opacity: 0.9; margin-top: 15px; font-weight: 400; max-width: 600px; margin-left: auto; margin-right: auto;">
					Your central hub for course materials and academic articles.
				</p>
			</div>
		</header>

		<main style="max-width: 1100px; margin: 40px auto; padding: 0 20px; display: grid; grid-template-columns: 1fr 350px; gap: 40px;">
			
			<section>
				<h2 style="font-size: 1.5rem; margin-bottom: 25px; color: #0f172a;">📖 Latest Articles</h2>
				
				{articles && articles.length > 0 ? (
					<div style="display: grid; gap: 24px;">
						{articles.map((post: any) => (
							<article style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 32px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); unicode-bidi: plaintext;">
								<small style="color: #64748b; font-weight: 600;">
									{post.date ? new Date(post.date).toLocaleDateString() : "General Update"}
								</small>
								<h3 style="font-size: 1.65rem; margin: 12px 0; color: #1e3a8a;">{post.title}</h3>
								<p style="color: #475569; margin-bottom: 24px; font-size: 1.05rem;">
									{post.content ? post.content.substring(0, 180) : "No content available"}...
								</p>
								<a href={`/articles/${post.title}`} style="display: inline-block; background: #2563eb; color: white; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-weight: 600; transition: background 0.2s;">
									Continue Reading →
								</a>
							</article>
						))}
					</div>
				) : (
					<div style="background: #f1f5f9; padding: 40px; border-radius: 16px; text-align: center;">
						<p style="color: #64748b;">No articles found in the library yet.</p>
					</div>
				)}
			</section>

			<aside style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 24px; position: sticky; top: 20px;">
				<h2 style="font-size: 1.25rem; margin-bottom: 20px; color: #0f172a;">📄 Resources</h2>
				
				{lectures && lectures.length > 0 ? (
					<div style="display: grid; gap: 12px;">
						{lectures.map((lecture: any) => (
							<div style="padding: 16px; border-radius: 10px; background: #f8fafc; border: 1px solid #f1f5f9;">
								<p style="margin: 0 0 12px 0; font-weight: 600; font-size: 0.95rem; color: #334155;">{lecture.title}</p>
								{lecture.fileURL && (
									<a href={`${lecture.fileURL}?dl=`} target="_blank" style="display: block; text-align: center; border: 1px solid #059669; color: #059669; padding: 8px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 700;">
										Download PDF
									</a>
								)}
							</div>
						))}
					</div>
				) : (
					<p style="color: #94a3b8; text-align: center;">No materials listed.</p>
				)}
			</aside>
		</main>

		<footer style="margin-top: 100px; padding: 60px 20px; background: #0f172a; color: #94a3b8; text-align: center;">
			<p style="margin: 0; font-weight: 600; color: white;">{siteTitle}</p>
			<p style="margin-top: 8px; font-size: 0.9rem;">&copy; {new Date().getFullYear()} — Built for Education</p>
		</footer>

	</body>
</html>